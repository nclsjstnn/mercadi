{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<slug>[^.]+)\\.mercadi\\.cl"
        }
      ],
      "destination": "/store/:slug/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/billing",
      "schedule": "0 13 * * *"
    }
  ]
}
