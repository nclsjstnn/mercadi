MONGODB_URI=mongodb://localhost:27017/mercadi
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
GEMINI_API_KEY=your-gemini-api-key-here
STOREFRONT_BASE_DOMAIN=localhost
BREVO_API_KEY=your-brevo-api-key-here
BREVO_FROM_EMAIL=noreply@mercadi.cl

# Transbank OneClick (platform subscription billing — Mercadi charges tenant admins)
# Leave TBK_ONECLICK_ENVIRONMENT=integration to use Transbank public test credentials automatically.
TBK_ONECLICK_ENVIRONMENT=integration
TBK_ONECLICK_COMMERCE_CODE=
TBK_ONECLICK_CHILD_COMMERCE_CODE=
TBK_ONECLICK_API_KEY=

# Vercel Cron secret (set the same value in Vercel dashboard → Settings → Environment Variables)
CRON_SECRET=

# Platform-managed integration (sandbox) credentials
# Tenants on "integration" mode use these — they never enter their own test keys.
# Transbank: public test credentials (safe to keep as defaults)
TBK_INTEGRATION_COMMERCE_CODE=597055555532
TBK_INTEGRATION_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
# MercadoPago: requires Mercadi's own sandbox account credentials
MP_INTEGRATION_ACCESS_TOKEN=
MP_INTEGRATION_PUBLIC_KEY=
MP_INTEGRATION_WEBHOOK_SECRET=
